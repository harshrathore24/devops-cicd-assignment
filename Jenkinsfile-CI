pipeline {

    agent any

    environment {
        IMAGE_NAME = "devops-cicd-assignment"
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('app') {
                    sh 'npm install'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('app') {
                    sh 'npm test'
                }
            }
        }

        stage('Docker Login') {

            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-credentials',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {

                    sh '''
                    echo "$DOCKER_PASS" | docker login \
                    -u "$DOCKER_USER" \
                    --password-stdin
                    '''

                }

            }

        }

        stage('Build Image') {

            steps {

                dir('app') {

                    sh '''
                    docker build \
                    -t $DOCKER_USER/devops-cicd-assignment:'"$BUILD_NUMBER"' \
                    -t $DOCKER_USER/devops-cicd-assignment:latest .
                    '''

                }

            }

        }

        stage('Push Image') {

            steps {

                sh '''
                docker push $DOCKER_USER/devops-cicd-assignment:'"$BUILD_NUMBER"'

                docker push $DOCKER_USER/devops-cicd-assignment:latest
                '''

            }

        }

        stage('Trigger CD Pipeline') {

            steps {

                build job: 'CD-Pipeline',

                parameters: [

                    string(
                        name: 'IMAGE_TAG',
                        value: BUILD_NUMBER
                    )

                ]

            }

        }

    }

    post {

        always {

            sh 'docker logout || true'

        }

    }

}